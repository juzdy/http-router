<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    bootstrap="../../../vendor/autoload.php"
    cacheDirectory=".pest/.cache"
    colors="true"
>
    <testsuites>
        <testsuite name="Juzdy HTTP Router Tests">
            <directory suffix="Test.php">tests</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory suffix=".php">src</directory>
        </include>
        <exclude>
            <directory suffix=".php">src/Example</directory>
            <directory suffix=".php">src/Contract</directory>
            <directory suffix=".php">src/Request</directory>
            <directory suffix=".php">src/Exception</directory>
            <directory suffix=".php">src/Handler</directory>
            <directory suffix=".php">src/Middleware</directory>
            <file>src/RouterInterface.php</file>
            <file>src/Route/RouteInterface.php</file>
        </exclude>
    </source>
</phpunit>
