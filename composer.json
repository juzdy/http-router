{
    "name": "juzdy/http-router",
    "description": "The JUZDY HTTP Router middleware",
    "keywords": [
        "php",
        "psr",
        "http",
        "router"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Victor Galitsky",
            "email": "concept.galitsky@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "juzdy/app": "dev-main",
        "juzdy/app-http": "dev-main",
        "juzdy/config": "dev-main",
        "psr/container": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Juzdy\\Http\\Router\\": "src/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Juzdy\\Http\\Router\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php ../../../vendor/bin/pest --configuration=pest.xml",
        "test:watch": "@php ../../../vendor/bin/pest --configuration=pest.xml --watch",
        "test:coverage": "@php ../../../vendor/bin/pest --configuration=pest.xml --coverage"
    },
    "extra": {
        "juzdy": {
            "config": "etc/config"
        }
    },
    "config": {}
}
